@model IEnumerable<Laboratorio04.Models.Producto>

@{
    ViewData["Title"] = "Catálogo de Productos";
}

<h1>Catálogo de Productos</h1>

<p>
    <a asp-action="Crear" class="btn btn-primary">Crear Nuevo Producto</a>
</p>

@if (Model != null && Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Categoría</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var producto in Model)
            {
                <tr>
                    <td>@producto.Id</td>
                    <td>@producto.Nombre</td>
                    <td>@producto.Precio.ToString("C")</td>
                    <td>@producto.Categoria</td>
                    <td>
                        <a asp-action="Detalles" asp-route-id="@producto.Id" class="btn btn-info btn-sm">Detalles</a>
                        <a asp-action="Editar" asp-route-id="@producto.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Eliminar" asp-route-id="@producto.Id" class="btn btn-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No hay productos registrados.</p>
}
