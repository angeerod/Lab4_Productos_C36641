@model Laboratorio04.Models.Producto

@{
    ViewData["Title"] = "Detalles del Producto";
}

<h1>Detalles del Producto</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Id</dt>
        <dd class="col-sm-9">@Model.Id</dd>
        
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>
        
        <dt class="col-sm-3">Precio</dt>
        <dd class="col-sm-9">@Model.Precio.ToString("C")</dd>
        
        <dt class="col-sm-3">Categoría</dt>
        <dd class="col-sm-9">@Model.Categoria</dd>
    </dl>
</div>

<div>
    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-editar">Editar</a>
    <a asp-action="Index" class="btn btn-cancelar">Volver al Listado</a>
</div>