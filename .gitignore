*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Visual Studio cache files
[Ss]tyle[Cc]op.*
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs

# Others
node_modules/
*.Cache
ClientBin/
[Ss]tyle[Cc]op.*
~$*
*.bak
*.cache
*.ilk
*.log
*.lib
*.sbr
*.sdf
*.opensdf
